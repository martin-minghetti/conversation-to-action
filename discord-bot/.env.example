# Discord bot token — from Discord Developer Portal
DISCORD_TOKEN=

# Shared secret — must match DISCORD_BRIDGE_SECRET in the main app
DISCORD_BRIDGE_SECRET=

# Vercel API URL — where the bot forwards normalized events
VERCEL_API_URL=https://your-app.vercel.app/api/events/discord

# Workspace and connection IDs — from your Supabase setup
WORKSPACE_ID=
CONNECTION_ID=

# Comma-separated channel IDs to monitor
MONITORED_CHANNELS=
